{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "hippocampus hook auto --claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|WriteFile",
        "hooks": [
          {
            "type": "command",
            "command": "hippocampus hook auto --claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "hippocampus hook summarize --claude"
          }
        ]
      }
    ]
  }
}
